# Copy this file to .env if you want to save your Todoist API token locally.
# Never commit .env.
#
# Find your token in Todoist:
# Settings -> Integrations -> Developer -> API token
TODOIST_TOKEN=your_todoist_api_token_here

# Completed-task scans start from this timestamp.
# Use an early date for a full account-history scan.
TODOIST_COMPLETED_SINCE=2000-01-01T00:00:00Z
